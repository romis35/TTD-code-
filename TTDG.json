      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Explore all 9 uniquely-themed worlds and make sure to hop on the 26 rides and attractions."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Rides and Attractions: The major rides you should prioritize are Planet of the Apes, Independence Day, Acorn Adventure, and the Epic water ride."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Robots Rivet Town: Assemble for non-stop family fun in the vibrant world of Robots!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Ice Age: A pre-historic adventure with attractions inspired by the globally recognized franchise, Ice Age."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Central Park: Gather in the buzzing town square to experience the best of world-class attractions, dining, retail and live entertainment."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Enjoy nine themed worlds and 26 rides. Park admission from 11am onwards. Guests are advised to use SkyAvenue Gateway at Level G, SkyAvenue (near Jom Makan) during regular hours; Studio Plaza entry is reserved for hotel guests. Guests visiting Genting SkyWorlds and Gohtong Way should use SkyAvenue Gateway for admission."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Explore Our Worlds:"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "- Studio Plaza: Begin the day's adventure at the majestic Studio Plaza. As a celebration of all things cinema, find your favourite movie characters in all shapes and forms - carved into the golden interiors, displayed at the 360° Legends Cinema or as collectibles in our exciting dining and retail stores!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "- Eagle Mountain: Step into the heat of a Californian desert right here at Eagle Mountain. As Torque and Wrench prepare for the infamous race of Mad Ramp Peak, grab a burger or two from the food trucks nearby or have a browse around the industrial themed Freedom Shop!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "- Central Park: Gather in the buzzing town square to experience the best of world-class attractions, dining, retail and live entertainment. Whether it's a visit to the Natural History Museum or the marvellous fountain show at the Lake of Dreams, Central Park is where fun, excitement and memory-lasting moments meet."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "- Andromeda Base: In this thrilling galactic escapade, your survival on Andromeda Base is put to the test in various challenges, including the looming Terraform Tower of terror!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "- Liberty Lane: Inspired by the streets of San Francisco, this thriving neighbourhood comes to life with unique stores, food locations, and an exhilarating attraction from Planet of the Apes – a first-in-the-world, designed exclusively for Genting SkyWorlds."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "- Robots Rivet Town: Assemble for non-stop family fun in the vibrant world of Robots!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "- Ice Age: A pre-historic adventure with attractions inspired by the globally recognized franchise, Ice Age. Experience mammoth-sized fun for everyone in the family!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Standard admission to Genting SkyWorlds Theme Park on your selected date."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Non-Malaysian Adult 1 Day Ticket includes an F&B/retail voucher (per ticket terms)."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Operation Hours: Please kindly visit Resorts World Genting official website for any updates. The park is normally closed on Tuesdays except on Malaysia national public holidays and school holidays."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Weather: Located 6,000ft above sea level, the weather does change often including cloudy conditions and rain. Kindly visit the official website for more info."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restrictions: Admission to the attractions is restricted by age and height requirements. Child tickets are height-based: Adult above 110cm, Child 90cm–110cm, free admission below 90cm, Senior aged 60 and above. Malaysian rates require physical MyKad for verification."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Show your mobile ticket at the ticketing counter. You can book Virtual Queue (VQ) only after scanning at the turnstile on your visit date. Scan the QR code at the park turnstile and register biometric before entry. Without the Genting SkyWorlds app, retain your admission ticket for re-entry. Do not activate or link ticket codes until you are at the attraction."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Ticket valid on selected date only. Non-transferable, non-refundable, not for resale; no validity date changes after purchase. Rainy Day Guarantee applies only to eligible ticket types and channels if it rains continuously for one hour during operating hours. Details: https://www.gentingskyworlds.com/en/tickets/rainy-day-guarantee.html"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "No cancellation for this activity as per vendor policy."
              }
            ]
          }
        }
