      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Enjoy a fun day at Genting SkyWorlds theme park with this day pass! Explore all 9 uniquely-themed worlds and make sure to hop on the 26 rides and attractions. Bring the whole family for a full day of fun and adventure!"
          }
        ]
      },
      "rating": {
        "average_value": 4.2,
