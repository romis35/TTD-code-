                "text": "EkspreSmiles Rewards: By becoming an EkspreSmiles member, you can start earning points to get a discount on your future ticket purchases."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Concession Fares with MyKad: You can use your MyKad directly at the gate to enjoy Concession Fares."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "KLIA Transit TravelCard Savings: You can register online, activate your MyKad, and reload to use TravelCard directly at the gate."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "KLIA Ekspres operates a closed ticketing system – this means that before you board a KLIA Ekspres train at any Station you must have purchased a ticket for your journey."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
