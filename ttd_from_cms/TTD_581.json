            "localized_texts": [
              {
                "language_code": "en",
                "text": "KLIA Ekspres is a non-stop, airport rail link service between Kuala Lumpur Sentral (KL Sentral) and the Kuala Lumpur International Airport (KLIA) and KLIA2."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Fastest Way to KLIA: KLIA Ekspres is the fastest way to travel from KL Sentral to KLIA."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
