          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Expect a fun-filled outdoor adventure suitable for all ages. After a safety briefing, hop onto the Skyride chairlift to the top of the track. From there, take control of your three-wheeled luge cart and cruise down specially designed tracks featuring exciting curves, slopes, and tunnels.Each ride offers a different experience depending on your chosen track and speed. You can purchase multiple rides to maximize the fun. Safety measures and trained staff are available throughout the attraction to ensure a smooth experience."
              }
            ]
          }
        },
