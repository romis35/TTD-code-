      "id": "product-727",
      "title": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Langkawi Tanjung Rhu Mangrove Speedboat Tour"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Embark on an enchanting Tanjung Rhu tour exclusively designed to reveal a different side of Langkawi! Cruise peacefully through a lush mangrove forest, where iconic local sea eagles gracefully hover above, creating a mesmerizing experience. Immerse yourself in the allure of the renowned mangrove forest, visiting attractions like Crocodile Cave, Bat Caves, and more. This comprehensive tour blends natural beauty with fascinating landmarks, offering a diverse and enriching experience. Tailor your adventure with the flexibility to choose between a shared or private tour, ensuring your preferences are seamlessly met. Whether opting for shared exploration with fellow travelers or a private journey, this Tanjung Rhu tour promises an unforgettable discovery of Langkawi's hidden gems. Book now to unveil the enchanting side of this destination!"
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Delve into the renowned mangrove forest and visit notable attractions such as Crocodile Cave, Bat Caves, and more!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Embark on a boat journey through a mangrove forest, accompanied by the iconic local sea eagles"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Enjoy the flexibility to opt for either a shared or private tour, tailored to cater to your specific preferences"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "This tour is designed to reveal a different and enchanting side of Langkawi, allowing you to uncover the destination's hidden gems and experience its charm with the fascination of unique landmarks, providing a diverse and enriching exploration.Mangrove Forest Cruise: You'll peacefully cruise through a lush mangrove forest, a unique ecosystem teeming with life. Keep an eye out for the iconic local sea eagles soaring overhead.Diverse Sights: Immerse yourself in the wonders of the mangrove forest, visiting intriguing attractions like Crocodile Cave and Bat Caves.Nature and Landmarks: This tour blends the beauty of the natural world with fascinating landmarks, offering a well-rounded experience.Shared or Private Tour:  Choose between a shared tour for a social experience or a private tour for a more intimate adventure."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "The tour likely involves some walking and getting on and off the boat. Consider your fitness level."
