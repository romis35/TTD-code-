        "localized_texts": [
          {
            "language_code": "en",
            "text": "Experience eco-tourism at Kampung Sungai Melayu, an environmentally responsible boat tour designed to connect with nature while supporting the local community. This tour offers a unique opportunity to appreciate the natural environment through activities like mangrove exploration, crab catching, and visiting a mussel farm. It's a journey that promotes conservation and provides an educational insight into the area's ecology and traditional practices."
          }
