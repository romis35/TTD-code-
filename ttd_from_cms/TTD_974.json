            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "These attractions include the Tornado Chaser, Kamikaze Racer, 1 Big Wave Pool, Adventure Island, and more!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "You can also enjoy lake activities like pedal boat rides as well as rabbit and fish feeding to maximize your fun!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Melaka Wonderland Theme Park is a famous waterpark with 11 exhilarating and water-splashing attractions."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Try the multi-level active water play structure that combines 8 slides into one big playground."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Expect a splashing good time at Melaka Wonderland! Dive into a world of fun with thrilling water slides, a relaxing lazy river, and a wave pool perfect for families. Enjoy the excitement of rafting with friends or simply relax and soak up the sun poolside. Kids and adults alike will love the interactive water play areas, while the park's commitment to cleanliness ensures a safe and enjoyable experience for everyone."
              }
            ]
          }
        },
        {
