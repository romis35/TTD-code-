      "id": "product-352",
      "title": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "KL Hop On Hop Off Pass"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Let us take you through every aspect of Kuala Lumpur - from the high-rise buildings and skyscrapers to the historical places and green scenery in this attractive and recreational tour. Worry no more, as you can be the timekeeper for your own travel. KL Hop On Hop Off is the ONLY OPEN TOP Double Deck bus in Kuala Lumpur, with lively guides and helpful ground crew to assist you during the tour. It's also famous as the main transport that connects to more than 60 sites and attractions in Kuala Lumpur and is recognized as a tourist-friendly transportation system. With 27 designated stops, you will get to know Kuala Lumpur like never before. Red Line (City Route) - 1 loop approximately 2 hours Stop.1 - Bukit Bintang (Interchange Stop) Stop 2 - Sheraton (Jalan Sultan Ismail) Stop 3 - Seri Pacific (Putra World Trade Center - PWTC) Stop 4 - Intercontinental Stop 5 - KLCC (Petronas Twin Towers) Stop 6 - Matic (Malaysia Tourism Centre) Stop 7 - KL Tower (Menara Kuala Lumpur) Stop 8 - KL City Walk Stop 9 - Aquaria Stop 10 - Changkat (Jalan Alor) Stop 11 - Swiss Garden Stop 12 - Chinatown Green Line (Garden Routes) - 1 loop approximately 2 hours Stop 13 - Central Market Stop 14 - Dataran Merdeka (Independence Square) Stop 15 - Little India Stop 16 - KL Sentral (Transit Hub to KL International Airport) Stop 17 - National Museum Stop 18 - National Palace (King's Residence) Stop 19 - Lake Garden Stop 20 - Bird Park Stop 21 - National Mosque Stop 22 - Merdeka Square (Independence Square) Stop 23 - Medan Mara Stop 24 - Chow Kit Stop 25 - Quill City Mall Stop 26 - Concorde (Hard Rock Cafe) Stop 27 - Tribeca Hotel"
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Double-Decker Bus: Discover Kuala Lumpur’s major landmarks on an air-conditioned double-decker with an open top deck."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Two Routes: The service operates two routes - the City Route (Red Line) and the Garden Route (Green Line), each offering a unique set of attractions."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Audio Commentary: The service provides an English audio commentary, offering interesting insights about the city and its attractions."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Let us bring you to the every aspect of Kuala Lumpur. From the hi-rise building up to the skyscrapers, towards the historical places and the green scenery that amidst of this attractive and recreational tour. Hassle free, worries no more, you are the timekeeper for your own travel.The ONLY OPEN TOP Double Deck bus in Kuala Lumpur, with the lively guide and the helpful ground crew to assist you during the tour. KL Hop On Hop Off also famous for the main transport that connected to more than 60 sites &amp; attractions in Kuala Lumpur, it is also being recognized as a tourist-friendly transportation system. With a 27 designated stops, you will get to know Kuala Lumpur like never before."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
