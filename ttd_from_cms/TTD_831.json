      "title": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Just Farm by Just Pets Megastore Ticket (Malaysia Largest Indoor Petting Zoo)"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Welcome to Just Pets Megastore at Tropicana Garden Mall, Malaysia's largest pet shop spanning an impressive 99,000 square feet. As your one-stop pet solution, we offer an extensive range of over 500 animal species, with over 3,000 live animals to choose from. Conveniently located in a strategic setting, our megastore provides easy parking and an indoor shopping experience. Catering to everyone from young families to couples and passionate pet lovers, we aim to be the go-to destination for all your pet needs. Explore our vast selection and embark on a journey to discover the perfect companionship for your home."
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Find your perfect cuddle buddy among our range of adorable puppies, kittens, and small mammals, each waiting to bring joy to your home."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Discover a kaleidoscope of colors with our diverse selection of exotic bird species, including parrots, macaws, and cockatoos."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Stock up on premium pet supplies"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Dive into our aquatic wonderland and explore our vast collection of tropical fish, coral reefs, and mesmerizing aquarium setups."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Unleash your wild side with our assortment of reptiles, including snakes, lizards, and turtles, for those looking to add a unique touch to their home."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Welcome to Just Farm. An indoor farm that houses a vast array of species with facilities designed to replicate the natural surroundings of its animal residents. Meet our animal residents in comfort, without having to leave the city."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Accessibility: Obtain approved food from the feeding stations, and our zookeeper will guide you in feeding specific animals"
              }
            ]
          }
        },
        {
