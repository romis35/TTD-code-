  "products": [
    {
      "id": "product-837",
      "title": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Langkawi Mangrove Tours Package"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Discover the enchanting wonders of Langkawi's mangroves with our Mangrove Tours Package. Embark on a captivating journey through lush greenery and winding waterways, immersing yourself in the rich biodiversity of this unique ecosystem.The Langkawi Mangrove Tours Package offers an immersive and educational experience, perfect for those looking to explore Langkawi’s natural beauty and diverse ecosystems. With a mix of adventure, wildlife encounters, and relaxation, this tour promises a memorable day for all participants."
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Gain a deeper understanding of local culture and traditions with visits to nearby fishing villages"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Experience the thrill of watching majestic eagles swoop down to catch their prey during our exhilarating eagle feeding sessions."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Witness a plethora of wildlife species including exotic birds, monkeys, and elusive otters as they thrive in their natural habitat."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Venture into mysterious limestone caves nestled within the mangroves, unveiling hidden chambers and ancient formations."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Join knowledgeable guides who will lead you through the maze of mangrove forests, offering insights into the diverse flora and fauna."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Bat Cave:Venture into the mysterious Bat Cave, home to thousands of bats. Observe these nocturnal creatures in their natural habitat while learning about their importance to the ecosystem.Fish Farm:Visit a local fish farm to see a variety of marine life up close. Learn about traditional aquaculture practices and have the opportunity to feed some of the fish.Eagle Feeding:Witness the awe-inspiring sight of eagles swooping down to catch their prey. This eagle feeding session offers a thrilling experience and fantastic photo opportunities.Mangrove Sightseeing:Cruise through the intricate network of mangrove forests. Marvel at the diverse flora and fauna, and learn about the crucial role mangroves play in coastal protection and marine life.Crocodile Cave:Navigate through Crocodile Cave, named for its crocodile-shaped rock formations. This natural wonder is accessible during low tide and offers a unique exploration experience.Open Sea (Andaman Sea):Experience the vastness of the Andaman Sea as you move from the serene mangroves to the open waters. Enjoy the breathtaking seascapes and the refreshing sea breeze.Icon Kilim Geoforest Park:Discover the iconic Kilim Geoforest Park, a UNESCO-listed site known for its stunning karst landscapes, rich biodiversity, and geological significance.Tanjung Rhu View:Take in the panoramic views of Tanjung Rhu, one of Langkawi's most beautiful beaches. This spot is perfect for capturing stunning photographs and enjoying the natural scenery.Swimming at the Island Beach:End your tour with a relaxing swim at a secluded island beach. Enjoy the clear, turquoise waters and pristine sands, perfect for unwinding after a day of adventure."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Carry a water bottle to stay hydrated. Light snacks may be provided, but you can bring your own if you have specific dietary needs."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Bring essentials such as sunscreen, a hat, sunglasses, swimwear, a towel, and insect repellent. A waterproof bag is recommended to protect your belongings."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Check the weather forecast before the tour. In case of adverse weather, the tour may be rescheduled or canceled for safety reasons."
