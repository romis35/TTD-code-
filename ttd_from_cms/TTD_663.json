        "localized_texts": [
          {
            "language_code": "en",
            "text": "Langkawi Car Rental Services"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "- Gear up for a remarkable trip around Langkawi aboard an air-conditioned car straight from the airport or jetty- Enjoy a full-day road trip on the island and visit its most popular attractions such as Tanjung Rhu Beach- Choose a multi-day car rental if you want to take more time exploring the island- See one of the largest aquariums in Malaysia when you visit [Langkawi Underwater World]"
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
