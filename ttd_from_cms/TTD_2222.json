              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Enjoy dynamic shows blending tradition and innovation, showcasing Melaka’s rich cultural heritage in a creative way"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Experience Southeast Asia’s first 360-degree rotating auditorium with advanced stage technology for immersive performances"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Located near UNESCO World Heritage Sites, Encore Melaka elevates the region as a global tourist destination"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "ENCORE MELAKA is an immersive performance with a series of untold stories of Melaka, which reflects a society that embraces diversity and inclusiveness. This 70-minutes long mega show reminiscing life stories of the locals with state-of-the-art production sets.&nbsp;The audience will experience 360-degree rotating audience platform fronting a 240-meter long stage, multi-lifting platforms, sound &amp; light and a 3D mapping projection that creates virtual reality that travels through time.&nbsp;Encore Melaka Theatre is a multi-venue performing arts center in Melaka City.This award-winning architectural venue where it continuously develops to be a vibrant performing arts theatre&nbsp;in Malaysia, providing a venue that continues to inspire and revitalize your life with the best experiences.&nbsp;Encore Melaka is able to accommodate a wide range of events including events, performances, product launching,&nbsp;movie premiers, film shoots, award ceremonies, seminars, exhibitions, meetings, and other corporate events."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restriction: Dangerous materials & items such as bottles, firecrackers, lasers, & other things that may disturb or inconvenience other attendees are prohibited"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restriction: Outside food and drinks are not allowed inside the venue"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restriction: Children under 4 years old are not recommended to watch the show"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restriction: Children under the age of 12 must be accompanied by an adult; regardless of age, all guests have to hold a valid ticket for admission"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restriction: Smoking and drinking is not allowed. You will immediately be asked to leave if caught by a staff member"
              }
