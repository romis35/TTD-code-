        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Encore Melaka, the brainchild of Datuk Wira Boo Kuang Loon, founder and CEO of Yong Tai Berhad. The planning of this theatre began in 2013 and the first performance was held on 7 July 2018. This award-winning architectural marvel, the first of its kind in Southeast Asia, features a unique 360-degree rotating auditorium with a seating capacity of 1,800 and a 240-meter-long stage equipped with advanced technology, including water, mist, multi-lifting, and multi-storey stages. The vision behind Encore Melaka is to blend tradition with innovation, offering dynamic, immersive performances that creatively present Melaka’s rich heritage. Strategically located near Melaka’s UNESCO World Heritage Sites, this premier cultural hub aims to elevate Melaka’s status as a global tourist destination, fostering economic growth and creating job opportunities for the local community."
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
