        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "The opportunity of a life time to Touch&Take photo with Tigers"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Enjoy a variety of cuisines at the park’s restaurant, which offers a wide selection of Thai and international dishes"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Natural & Clean Park :  Stroll through well-maintained grounds featuring lush greenery and a serene atmosphere."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Cafe : Unwind at the Tiger Cafe, where you can enjoy a range of beverages and snacks."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Once in a lifetime, you'll have the opportunity to take a selfie in a cage with a magnificent, unchained tiger. Don't miss this chance at Tiger Park, Pattaya. Here, you can play, hug, kiss, and snap photos with the tiger without any worries. These tigers are born and raised under the care of experienced staff and in an environment designed to ensure they can live happily alongside"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
