      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Space &amp; Time Cube – Malaysia’s First Immersive Naked-Eye 3D ExperienceLocated at Lot 10 Kuala Lumpur, Space &amp; Time Cube is Malaysia’s first immersive nakedeye 3D experience center, redefining entertainment with cutting-edge visual storytelling,interactive design, and futuristic technology. This unique attraction allows visitors to exploremulti-sensory, multi-dimensional journeys—without the need for 3D glasses or VRheadsets."
          }
        ]
      },
