      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Knead away your stress and relax your muscles with our magical touch massageIndulge in the ultimate relaxation with our luxurious massage treatments that will transport you to a state of pure bliss. Our skilled therapists will knead and soothe your muscles with the perfect amount of pressure, leaving you feeling refreshed and rejuvenated. Whether you need to release tension or simply want to pamper yourself, our magical touch massage is the perfect way to unwind and recharge."
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Cream-based full-body massage that involves deep thumb pressure pushing, pressing, and circling along and around the body to relieve muscle tension."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "The warmth of the hot stones helps to warm up your tight muscles and improve your blood circulation."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "A type of massage that heated smooth flat stones will be placed on key points of your body."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "A type of treatment for the body that exfoliates your skin to achieve smoother and softer skin. Doing Body Scrub on regular basis helps to achieve brighter skin"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Traditional massage uses warm essential oil to stimulate circulation, ease muscular and joint pain, and bring a sense of well-being, calm and deep relaxation."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Experience ultimate relaxation with our Magical Touch Massage, designed to knead away your stress and soothe your muscles. Our skilled therapists apply the perfect amount of pressure to leave you feeling refreshed and rejuvenated. Whether you're looking to release tension or indulge in self-pampering, our luxurious massage treatments will transport you to a state of pure bliss, ensuring you unwind and recharge completely."
              }
            ]
          }
        },
