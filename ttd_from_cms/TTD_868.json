      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Embark on an extraordinary journey at Zoo Teruntum in Kuantan, where the realms of tradition and cutting-edge technology converge seamlessly. This one-of-a-kind destination offers an immersive experience that combines the charm of a traditional zoo with the excitement of animatronics. With over 25 captivating animal species and lifelike animatronic creatures, Zoo Teruntum promises an adventure that transcends the ordinary."
          }
        ]
      },
