        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Terms & Conditions: Ticket sold is for access to Level 18’s Sky Lounge and Level 33’s Sky Deck (the “Attractions”) only. Child ticket is valid for age 3-12 years old Adult ticket is valid for age 13-60 years old Senior ticket is valid for age 61 years and above Free entry for children below 3 years old Tickets will only be exchanged or refunded if PIPPSB, in its absolute discretion, chooses to do so. To the extent permitted by law, any request for refunds or cancellations for tickets purchased due to adverse weather conditions will NOT be entertained. Proof of identification is to be presented for registration and check-in on the day of the event FREE entry for children below 3 years old. NO outside food and drinks are allowed in the Sky Lounge and Sky Deck. One (1) ticket admits one (1) person only. Visitors below 12 years old must be accompanied by parents/guardians. Parents and guardians understands that it is their responsibility to ensure compliance with the terms & conditions by themselves and any minors under their care, and warrants that they will take all reasonable effort to ensure that they do not breach their duty of care towards the minor(s). Smoking and chewing gum are not permitted during visits. Visitors MUST comply with the Maha Tower rules and regulations, which include the signs and notices displayed in/on and/or around the premises."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Cancellation Policy: Free cancellation if cancelled till the selected date."
              }
            ]
          }
        }
