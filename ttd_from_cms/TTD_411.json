      "title": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Maha Tower"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Indulge in the sky-high delights of the Maha Tower as you set sail on an unforgettable seaside adventure along the coast of the Andaman Sea. Poised to be the leading leisure and business hub in Langkawi, the tower features a transcendent sky-high experience that elevates, excites, and awakens your senses. A quintessential Langkawian experience not to be missed."
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Glimpse of spectacular sunset"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Enjoy a 360° view of Andaman Sea and city of Kuah from 102meter top"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Offers transcendent sky-high experience"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Indulge in a world-class leisure experience on the Maha Tower esplanade, where you’ll find a curated collection of wonders that cater to everything you need, all in one place. Blending the best of retail with sky-high splendour, the Maha Tower experience is specially curated to awaken your senses, boasting a unique charm that you can’t get elsewhere.The tower’s unique tilted viewing window also allows visitors to “hover” over the panoramic views of the bustling crowds dotted around the esplanade, coupled with the magical sparkle of the vast Andaman Sea.More than a world-class destination for stunning vistas, the Maha Tower is also a hub for elevated leisure experiences that keep you engaged and inspired with a curated selection of activities."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Accessibility: FREE entry for children below 3 years old."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restriction: NO outside food and drinks allowed in the Sky Lounge and Sky Deck."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
