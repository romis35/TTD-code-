      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Glass Museum Penang achieved 2 records in The Malaysia Book of Records : “ The First Glass Museum” & “Longest Batik Motive Glass Painting”. The museum specialized in Fused Glass, Sandblasted Glass, Batik Glass & Creative Art Glass. The museum turn glass into unique decoration products,like glass key chain, clock,deco products,glass jewelry and even customized glass gifts."
          }
        ]
      },
