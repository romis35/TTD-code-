          {
            "language_code": "en",
            "text": "Amverton Riverine Splash"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Riverine Splash is a tribal-themed waterpark designed with lush landscape &amp; fun rides for all ages. Keep your entire family entertained, ride our Boa and Anaconda Tube slides to get your adrenaline pumping or take a relaxing cruise along our Rimba River and immerse yourself in the sights and sounds of nature at its best."
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "The park offers an array of slides, rides, and relaxing attractions for all ages."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "It features adrenaline-pumping slides with rainbow colours as you slide down."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "The park includes a Waveball pool, one of the first in Malaysia."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "The Batufall (waterfall) is a safe and ideal place for couples or families to chill together."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "At Amverton Riverine Splash, immerse yourself in a world of aquatic fun, family entertainment, and relaxation, promising a day filled with memorable water-based adventures for guests of all ages. A unique Tribal themed destination, Over 12 rides, slides & attractions."
              }
            ]
          }
        },
        {
