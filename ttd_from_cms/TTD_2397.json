      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Our ice rink is a premier destination for skaters of all ages and abilities. With certified coaches, a fully stocked pro shop, and a variety of programs, we offer a safe and enjoyable skating experience. Our session-based ticket entry system ensures a comfortable and manageable environment for all skaters. Whether you're a beginner or an experienced athlete, we have something to offer. Come join us for a fun and memorable skating experience."
          }
        ]
