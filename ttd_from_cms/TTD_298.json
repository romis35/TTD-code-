  "products": [
    {
      "id": "product-298",
      "title": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Crocodile Adventureland Langkawi"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Crocodile Adventureland is home to around 4,000 young and mature species of crocodile, including Tomistoma, Siamese, Guinea, and the Saltwater Crocodile. The farm is also home to 'Bujang Lang', one of the world's largest crocodiles in captivity weighing in at 1,000 kilograms. Engage in several activities including crocodile feeding and fishing, and come virtually face to face with life sized, crocodile like dinosaurs, in an interactive experience powered by animatronics technology."
          }
        ]
      },
      "rating": {
        "average_value": 4.3,
        "rating_count": 100
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Largest Collection of Crocodiles: The park is home to nearly 4000 crocodiles from various species such as Tomistoma, Siamese, Guinea, and Saltwater crocodile."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Educational and Entertaining: The park combines entertainment & education, featuring live shows that highlight the strength and agility of these reptiles."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Interactive Activities: The park offers interactive activities such as juvenile crocodile fishing and feeding."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Awards and Recognition: ‘Outstanding Eco Adventure Park’ by MyMalaysia Tourism in 2023.\""
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Dive into the heart of natural wonders at Treetopia and Crocodile Adventureland Langkawi, where your photography skills come alive. In the tranquil embrace of Treetopia, capture the elegance of towering trees and vibrant blooms. Explore the hanging bridge and embrace the beautiful scenery of mountains. Share your visual journey on social media, hashtag Treetopia Langkawi and tag Crocodile Adventureland Langkawi social media. Let your lens tell the story, and don't forget to tag us for a chance to be featured!&nbsp;&nbsp; &nbsp;"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "While some paved pathways exist, navigating the park with a wheelchair might be challenging."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Accessibility: The crocodile feeding shows can involve loud noises and sudden movements, which might be overwhelming for visitors with sensory sensitivities."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Restriction: Food and drinks are not permitted inside the crocodile enclosures."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "What’s included: 2 x pellet (Juvenile Crocodile Feeding)"
              }
            ]
          }
        },
