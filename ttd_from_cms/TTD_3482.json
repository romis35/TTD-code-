            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Terms & Conditions: All visitors must follow all rules and instructions from the staff at i-City Theme Park. Visitors participate in i-City Theme Park activities at their own risk. Parents or guardians are fully responsible for the supervision and safety of their children. i-City Theme Park is not responsible for any lost, stolen, or damaged items. Infants under 1 year old or those unable to walk independently are not allowed to enter SnoWalk and London Village for safety reasons. Disabled visitors (OKU), wheelchair users, and pregnant women must comply with the safety regulations and general terms and conditions of each attraction. Entry to SnoWalk and London Village is strictly prohibited for these groups. Strollers are not allowed on any rides except for Water World. Access to all i-City Theme Park attractions is subject to safety height restrictions and the park's general terms and conditions."
              }
            ]
