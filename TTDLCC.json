  "products": [
    {
      "id": "product-10",
      "title": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Langkawi Cable Car (SkyCab)"
          }
        ]
      },
      "description": {
        "localized_texts": [
          {
            "language_code": "en",
            "text": "Prepare for a visit to Langkawi's premier geo-theme park, Panorama Langkawi, with this combo ticket offering a day of fun activities. With SkyCab's base located in the Oriental Village, you'll be nestled in some of Southeast Asia's most ancient natural scenery! With your SkyCab cable car ticket, step into a SkyCab car for the ultimate mountain views in the area. Ride up Machincang mountain and reach an elevation of over 650 meters. Once up high, you'll witness SkyBridge, a suspended bridge with transparent pathing that offers visitors close-up views of the surrounding treetops."
          }
        ]
      },
      "rating": {
        "average_value": 4.4,
        "rating_count": 28500
      },
      "product_features": [
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Prepare for a visit to Langkawi's premier geo-theme park, Panorama Langkawi, with this combo ticket offering a day of fun activities."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "With SkyCab's base located in the Oriental Village, you'll be nestled in some of Southeast Asia's most ancient natural scenery!"
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_HIGHLIGHT",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "With your SkyCab cable car ticket, step into a SkyCab car for the ultimate mountain views in the area."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Hovering over jungle and climbing over 550 million years old rock, SkyCab gives you more than one unique experience. Be informed, SkyCab is located at the oldest part of South East Asia and the first to emerge from the ancient sea and estuary! That's something to give a goose bump if you can get the gist. Come and experience it yourself."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_INCLUSION",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "The Base Station is conveniently located at the foothill of the Machincang mountain. From here, visitors will be taken up to the cool Machincang mountain via the cable car system. The ride will be an exhilarating experience for everyone to enjoy. You will also be able to catch a glimpse of the flora and fauna that surrounds the area."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Hours: Usually 9:30 AM–6:00 PM; during school holidays and Ramadan 1447H/2026 they vary (e.g. 9:00–6:00, 9:30–4:30; Hari Raya 21 Mar 2026 12:30–6:30 PM). Confirm on the official Panorama Langkawi website before you go."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Weather: SkyCab may close or change operations depending on weather and wind. Dress casually and wear comfortable shoes if visiting SkyBridge."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Redemption: Show mobile or printed voucher at the gantry with IC/passport. Some tickets need a selected date and time slot. Traveller name must match ID."
              }
            ]
          }
        },
        {
          "feature_type": "TEXT_FEATURE_MUST_KNOW",
          "value": {
            "localized_texts": [
              {
                "language_code": "en",
                "text": "Valid on selected date only; no outside food/drinks; no smoking. Age bands differ by product (many: adult 13+, child 3–12; some child 2–12; Express Lane add-on adult 13+ only; glass/360 gondola one rate per person). No vendor cancellation unless your sales channel says otherwise. From Kuah: ~30 min by taxi or car; buses are infrequent."
              }
            ]
          }
        }
      ],
